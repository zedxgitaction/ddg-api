{
  "builds": [
    {
      "src": "api/chat.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/edit/result",
      "dest": "api/chat.js"
    },
    {
      "src": "/api/edit",
      "dest": "api/chat.js"
    },
    {
      "src": "/api/chat/result",
      "dest": "api/chat.js"
    },
    {
      "src": "/api/chat",
      "dest": "api/chat.js"
    }
  ]
}